# API Configuration
PORT=8000
DATABASE_URL=postgresql://user:password@localhost:5432/prelexa

# OCR Service Configuration
# Local development (docker-compose)
OCR_SERVICE_URL=http://ocr-service:8001/extract

# Render deployment - uncomment and configure for your domain
# OCR_SERVICE_URL=https://prelexa-ocr.onrender.com/extract

# Or with custom domain
# OCR_SERVICE_URL=https://ocr.your-domain.com/extract

# Authentication
NEXT_AUTH_SECRET=your_secret_key_here
NEXT_AUTH_URL=http://localhost:3000

# Third-party APIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Other configurations
ENVIRONMENT=development
LOG_LEVEL=INFO
